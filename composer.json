{
    "name": "yezzmedia/laravel-ops-sites",
    "version": "0.1.1",
    "description": "Ops-facing site inventory, domain posture, and assignment visibility package for the Yezz Media Laravel platform.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/database": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.92",
        "yezzmedia/laravel-foundation": "^0.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "YezzMedia\\OpsSites\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YezzMedia\\OpsSites\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YezzMedia\\OpsSites\\OpsSitesServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G src tests",
        "format": "vendor/bin/pint --format agent"
    },
    "suggest": {
        "spatie/laravel-activitylog": "Optional audit persistence driver for ops sites audit events.",
        "yezzmedia/laravel-ops-infrastructure": "Optional infrastructure assignment enrichment for ops sites visibility.",
        "yezzmedia/laravel-ops-security": "Optional security enrichment for SSL assignment and edge posture visibility."
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
